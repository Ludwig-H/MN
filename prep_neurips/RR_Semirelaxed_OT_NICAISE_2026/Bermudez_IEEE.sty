\def\function#1#2#3#4{
\left\{
\begin{array}{@{}r@{~}c@{~}l@{}}
#1  &\longrightarrow&  #2 \\
#3  &\longmapsto&  #4 
\end{array}
\right.
}
\def\longfunction#1#2#3#4{
\left\{
\begin{array}{@{}r@{~}c@{~}l@{}}
&&#1  \longrightarrow  #2 \\
&&#3  \longmapsto   #4 
\end{array}
\right.
}

